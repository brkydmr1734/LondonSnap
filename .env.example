# LondonSnaps Environment Configuration
# Copy this file to .env and fill in the values

# ===========================================
# Database Configuration
# ===========================================
DATABASE_URL=postgresql://londonsnaps:your_password@localhost:5432/londonsnaps
DB_PASSWORD=your_secure_password

# ===========================================
# Redis Configuration
# ===========================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password

# ===========================================
# JWT Configuration
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-key
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# Supabase (Database + Storage)
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=media

# ===========================================
# Apple Sign In
# ===========================================
APPLE_CLIENT_ID=com.londonsnaps.app
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY=your_apple_private_key

# ===========================================
# Google Sign In
# ===========================================
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_IOS_CLIENT_ID=your_google_ios_client_id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your_google_android_client_id.apps.googleusercontent.com

# ===========================================
# Email Service (SendGrid)
# ===========================================
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@londonsnaps.app
EMAIL_FROM_NAME=LondonSnaps

# ===========================================
# Firebase (Push Notifications via FCM)
# ===========================================
FIREBASE_PROJECT_ID=londonsnaps-app
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@londonsnaps-app.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=your_firebase_private_key
# Or paste the full service account JSON:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# ===========================================
# App Configuration
# ===========================================
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
ADMIN_URL=http://localhost:8080
MOBILE_SCHEME=londonsnaps

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# Media Configuration
# ===========================================
MAX_FILE_SIZE=52428800
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif
ALLOWED_VIDEO_TYPES=video/mp4,video/quicktime,video/webm
IMAGE_QUALITY=80
VIDEO_MAX_DURATION=60

# ===========================================
# Story Configuration
# ===========================================
STORY_EXPIRATION_HOURS=24

# ===========================================
# Snap Configuration
# ===========================================
SNAP_DEFAULT_VIEW_TIME=5

# ===========================================
# Streak Configuration
# ===========================================
STREAK_RESET_HOURS=24

# ===========================================
# Moderation
# ===========================================
CONTENT_MODERATION_ENABLED=true
NSFW_DETECTION_ENABLED=true
MODERATION_THRESHOLD=0.7

# ===========================================
# Analytics
# ===========================================
MIXPANEL_TOKEN=your_mixpanel_token
AMPLITUDE_API_KEY=your_amplitude_key

# ===========================================
# Sentry Error Tracking
# ===========================================
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# ===========================================
# Feature Flags
# ===========================================
FEATURE_UNIVERSITY_VERIFICATION=true
FEATURE_EVENTS=true
FEATURE_DISCOVER=true
FEATURE_VOICE_MESSAGES=true
FEATURE_VIDEO_CALLS=false
