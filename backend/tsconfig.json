{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": "./src",
    "paths": {
      "@/*": ["./*"],
      "@auth/*": ["./auth/*"],
      "@media/*": ["./media/*"],
      "@chat/*": ["./chat/*"],
      "@stories/*": ["./stories/*"],
      "@snaps/*": ["./snaps/*"],
      "@social/*": ["./social/*"],
      "@events/*": ["./events/*"],
      "@discover/*": ["./discover/*"],
      "@notifications/*": ["./notifications/*"],
      "@moderation/*": ["./moderation/*"],
      "@common/*": ["./common/*"],
      "@database/*": ["./database/*"],
      "@config/*": ["../config/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}
