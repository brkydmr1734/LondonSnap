// ==================================================
// SAFETY WALK
// ==================================================

model SafetyWalk {
  id                String            @id @default(uuid())
  requesterId       String
  companionId       String
  status            SafetyWalkStatus  @default(PENDING)
  startLat          Float
  startLng          Float
  endLat            Float
  endLng            Float
  routePolyline     Json?
  estimatedDuration Int?
  transportMode     String            @default("WALKING")
  scheduledAt       DateTime?
  startedAt         DateTime?
  endedAt           DateTime?
  safetyScore       Float?
  sosTriggered      Boolean           @default(false)
  sosTriggeredAt    DateTime?
  sosTriggeredBy    String?
  chatId            String?           @unique
  chat              Chat?             @relation(fields: [chatId], references: [id])
  requester         User              @relation("SafetyWalkRequester", fields: [requesterId], references: [id])
  companion         User              @relation("SafetyWalkCompanion", fields: [companionId], references: [id])
  locationUpdates   SafetyWalkLocation[]
  ratings           SafetyWalkRating[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([requesterId, status])
  @@index([companionId, status])
  @@index([status, scheduledAt])
}

model SafetyWalkLocation {
  id          String     @id @default(uuid())
  walkId      String
  userId      String
  latitude    Float
  longitude   Float
  accuracy    Float?
  speed       Float?
  heading     Float?
  timestamp   DateTime   @default(now())
  walk        SafetyWalk @relation(fields: [walkId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id])

  @@index([walkId, userId, timestamp])
}

model SafetyWalkRating {
  id        String     @id @default(uuid())
  walkId    String
  raterId   String
  ratedId   String
  score     Int
  comment   String?
  createdAt DateTime   @default(now())
  walk      SafetyWalk @relation(fields: [walkId], references: [id], onDelete: Cascade)
  rater     User       @relation("SafetyRater", fields: [raterId], references: [id])
  rated     User       @relation("SafetyRated", fields: [ratedId], references: [id])

  @@unique([walkId, raterId])
}

model SafetyScore {
  id              String   @id @default(uuid())
  userId          String   @unique
  score           Float    @default(100.0)
  totalWalks      Int      @default(0)
  completedWalks  Int      @default(0)
  cancelledWalks  Int      @default(0)
  sosCount        Int      @default(0)
  avgRating       Float    @default(5.0)
  lastUpdatedAt   DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])
}
